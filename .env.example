# MCP Sentinel - Environment Configuration
# Copy this file to .env and fill in all values before running docker-compose up

# PostgreSQL
DB_USER=sentinel
DB_PASSWORD=                  # required: set a strong password
DB_NAME=mcp_sentinel
DB_PORT=5432

# Redis
REDIS_PASSWORD=               # required: set a strong password
REDIS_PORT=6379

# API
API_PORT=8000
LOG_LEVEL=info
ENVIRONMENT=production
SECRET_KEY=                   # required: generate with: python -c "import secrets; print(secrets.token_hex(32))"

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=              # required: set a non-default username
MINIO_ROOT_PASSWORD=          # required: set a strong password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Flower monitoring
FLOWER_PORT=5555

# AI Providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Integrations (optional)
JIRA_URL=
JIRA_API_TOKEN=
SLACK_WEBHOOK_URL=
