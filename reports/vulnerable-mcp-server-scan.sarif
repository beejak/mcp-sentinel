          "properties": {
            "vulnerability_id": "vuln-1774979201.805574",
            "title": "Insecure Deserialization: pickle.loads() on Untrusted Data",
            "confidence": "medium",
            "cwe_id": "CWE-502",
            "cvss_score": 9.8,
            "detector": "InsecureDeserializationDetector",
            "engine": "static",
