          },
          "fixes": [
            {
              "description": {
                "text": "1. Add @login_required / @auth_required decorator to the route function\n2. FastAPI: add Depends(get_current_user) to the function signature\n3. Express: add auth middleware before the handler: router.get('/admin', authMiddleware, handler)\n4. Consider IP allowlisting for admin endpoints in addition to auth\n5. If global middleware handles auth, add a comment to suppress this finding"
              }
            }
          ]
