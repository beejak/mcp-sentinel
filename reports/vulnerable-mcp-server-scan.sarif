            "owasp_asi_name": "Improper Error Handling / Path Traversal"
          },
          "fixes": [
            {
              "description": {
                "text": "1. Validate user input before path joining\n2. Check for absolute paths and reject them\n3. Sanitize '../' and '..' from user input\n4. Use path.resolve() after joining to normalize\n5. Verify result stays within intended directory\n6. Consider using only basenames from user input\n7. Implement allowlist of permitted paths"
