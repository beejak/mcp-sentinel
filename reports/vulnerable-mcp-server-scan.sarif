          "level": "error",
          "message": {
            "text": "Detected cross-tool manipulation directive: 'before calling'. Phrases like 'before calling', 'global rule', or 'always call this tool first' in tool descriptions are used in tool shadowing attacks. A malicious MCP server can embed these phrases to intercept all agent tool calls, even calls to tools on other trusted servers. This is the documented cross-server escalation / tool shadowing attack vector."
          },
          "locations": [
            {
              "physicalLocation": {
