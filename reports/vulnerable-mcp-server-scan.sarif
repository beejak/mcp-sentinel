        {
          "ruleId": "SSRF",
          "level": "error",
          "message": {
            "text": "Hardcoded cloud metadata service endpoint detected: '(\"aws_metadata\",     \"http://169.254.169.254/latest/meta-data/\"),'. The AWS Instance Metadata Service (169.254.169.254), GCP metadata (metadata.google.internal), and Azure IMDS are accessible from cloud instances. If an SSRF vulnerability exists anywhere in the server, attackers can use these endpoints to steal cloud credentials (IAM roles, service account tokens). This finding may indicate the server is aware of and interacts with metadata services."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "tests/fixtures/payloads.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 84,
                  "snippet": {
                    "text": "(\"aws_metadata\",     \"http://169.254.169.254/latest/meta-data/\"),"
                  }
                }
              }
            }
          ],
          "properties": {
            "vulnerability_id": "vuln-1774979203.13172",
            "title": "SSRF: Cloud Metadata Endpoint Reference",
            "confidence": "high",
            "cwe_id": "CWE-918",
            "cvss_score": 9.8,
            "detector": "SSRFDetector",
            "engine": "static",
            "mitre_attack_ids": [
              "T1552.005",
              "T1078.004"
            ],
            "owasp_asi_id": "ASI05",
            "owasp_asi_name": "Improper Output Handling / SSRF"
          },
          "fixes": [
            {
              "description": {
                "text": "1. Remove direct references to cloud metadata endpoints from application code\n2. Use IMDSv2 (AWS) which requires a PUT request with a session token\n3. Use IAM roles and SDKs instead of direct metadata endpoint access\n4. Block 169.254.169.254 at the network level with security groups/firewall rules\n5. Enable IMDSv2 only and set hop limit to 1 to prevent SSRF access"
              }
            }
          ]
        },
        {
