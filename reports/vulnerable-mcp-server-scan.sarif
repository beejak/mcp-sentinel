              "T1203"
            ],
            "owasp_asi_id": "ASI08",
            "owasp_asi_name": "Insecure Deserialization"
          },
          "fixes": [
            {
              "description": {
                "text": "1. Never use pickle to deserialize data from untrusted sources\n2. Use JSON, MessagePack, or Protocol Buffers for inter-process data\n3. If pickle is required: use HMAC signing to verify the payload first\n4. Consider `restrictedhash` or `SafeUnpickler` for controlled deserialization\n5. Sandbox pickle operations in a separate process with no network/filesystem access"
              }
            }
          ]
