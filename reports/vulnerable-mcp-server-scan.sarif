            "owasp_asi_id": "ASI05",
            "owasp_asi_name": "Improper Output Handling / SSRF"
          },
          "fixes": [
            {
              "description": {
                "text": "1. Remove direct references to cloud metadata endpoints from application code\n2. Use IMDSv2 (AWS) which requires a PUT request with a session token\n3. Use IAM roles and SDKs instead of direct metadata endpoint access\n4. Block 169.254.169.254 at the network level with security groups/firewall rules\n5. Enable IMDSv2 only and set hop limit to 1 to prevent SSRF access"
              }
            }
